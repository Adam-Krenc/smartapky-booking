# Google OAuth (Web application client)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# Target calendar (Settings → Integrate calendar → Calendar ID)
GOOGLE_CALENDAR_ID=

# Optional: defaults to obchod@smartapky.cz
# OFFICE_EMAIL=

# Optional Resend confirmation email sent to the booker after Google Meet is created.
# Requires verified smartapky.cz domain in Resend.
# RESEND_API_KEY=
# BOOKING_FROM_EMAIL=obchod@smartapky.cz
# BOOKING_FROM_NAME=Smartapky

# Upstash Redis (REST) — rate limit on POST /api/book
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional JSON: weekday 1=Mon … 7 → [openH, closeH] in whole hours, or {"from":"HH:MM","to":"HH:MM"}, or [oh,om,ch,cm].
# "to" is end of booking window: last 60 min slot ends at this time (e.g. 23:00 → last start 22:00).
# Příklad odpoledních začátků Po–Pá až do večera:
# WORK_HOURS={"1":{"from":"15:30","to":"23:00"},"2":{"from":"13:30","to":"23:00"},"3":{"from":"13:30","to":"23:00"},"4":{"from":"10:15","to":"23:00"},"5":{"from":"12:10","to":"23:00"}}

# Optional tuning
# TIMEZONE=Europe/Prague
# SLOT_MINUTES=60
# MIN_BOOKING_LEAD_HOURS=24
# MAX_BOOKING_DAYS=30
# BOOK_RATE_LIMIT_MAX=5
# BOOK_RATE_LIMIT_WINDOW_SEC=60

# Public link shown on booking page
# NEXT_PUBLIC_GDPR_PDF_URL=https://www.smartapky.cz/assets/legal/GDPR.pdf
