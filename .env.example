# Google OAuth (Web application client)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# Target calendar (Settings → Integrate calendar → Calendar ID)
GOOGLE_CALENDAR_ID=

# Optional: defaults to obchod@smartapky.cz
# OFFICE_EMAIL=

# Upstash Redis (REST) — rate limit on POST /api/book
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional JSON: ISO weekday 1=Mon … 7=Sun → [openHour, closeHour]
# Default Mon–Fri 9–17 Europe/Prague if unset.
# WORK_HOURS={"1":[9,17],"2":[9,17],"3":[9,17],"4":[9,17],"5":[9,17]}

# Optional tuning
# TIMEZONE=Europe/Prague
# SLOT_MINUTES=60
# MIN_BOOKING_LEAD_HOURS=24
# MAX_BOOKING_DAYS=30
# BOOK_RATE_LIMIT_MAX=5
# BOOK_RATE_LIMIT_WINDOW_SEC=60

# Public link shown on booking page
# NEXT_PUBLIC_GDPR_PDF_URL=https://www.smartapky.cz/assets/legal/GDPR.pdf
